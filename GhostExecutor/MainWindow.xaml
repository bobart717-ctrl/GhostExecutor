<Window x:Class="GhostExecutor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ghost" Height="300" Width="600" Background="#A0A0A0" 
        WindowStyle="None" AllowsTransparency="False"> 
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#A0A0A0" MouseLeftButtonDown="DragWindow">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="—" Click="MinimizeApp" Background="Transparent" BorderBrush="Transparent" Margin="5" FontWeight="Bold"/>
                <Button Content="☐" Click="MaximizeApp" Background="Transparent" BorderBrush="Transparent" Margin="5" FontWeight="Bold"/>
                <Button Content="✕" Click="CloseApp" Background="Transparent" BorderBrush="Transparent" Margin="5" FontWeight="Bold"/>
            </StackPanel>
        </Border>
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Ghost" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" FontFamily="Segoe UI"/>

        <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Background="Black" CornerRadius="15" Margin="5">
            <TextBlock Text="Soon" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20">
                <TextBlock.LayoutTransform>
                    <RotateTransform Angle="90"/>
                </TextBlock.LayoutTransform>
            </TextBlock>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="#8E8E8E" CornerRadius="15" Margin="5">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="10,5">
                   <Border Background="Black" CornerRadius="10" Padding="10,2">
                        <TextBlock Text="File1 +" Foreground="White"/>
                   </Border>
                </StackPanel>
                <TextBox x:Name="ScriptBox" Margin="10,35,10,10" Background="White" BorderThickness="0" 
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         Text="-- Start typing here!"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,0">
            <Button Content="Execute" Click="Execute_Click" Background="#FF4B4B" Foreground="Black" Width="150" Height="45" Margin="5" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Clear" Click="Clear_Click" Background="#B0B0B0" Width="150" Height="45" Margin="5" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="New File" Click="NewFile_Click" Background="White" Width="150" Height="45" Margin="5" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
